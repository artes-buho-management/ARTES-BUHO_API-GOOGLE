# Plantilla de variables de entorno
# Copiar a .env y rellenar. NO commitear .env.

# Cuenta Google a la que se conectan todas las APIs
GOOGLE_ACCOUNT_EMAIL=booking@artesbuhomanagement.com

# Google Cloud Project
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json

# OAuth2 (cliente de escritorio / web)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth2/callback

# Token OAuth persistido tras el primer flujo
# Se genera automaticamente en config/token.json (ignorado por git)

# API Keys sueltas
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
YOUTUBE_API_KEY=
